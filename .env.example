# Twitch app credentials
TWITCH_CLIENT_ID=your-twitch-client-id
TWITCH_CLIENT_SECRET=your-twitch-client-secret
TWITCH_REDIRECT_URI=https://your-domain.example/auth/twitch/callback
TWITCH_EVENTSUB_SECRET=replace-with-long-random-eventsub-secret

# Public app settings
APP_HOST=0.0.0.0
APP_PORT=8000
APP_PUBLIC_BASE_URL=https://your-domain.example
SESSION_SECRET=change-me-long-random-session-secret

TWITCH_REQUIRE_FOLLOWER_ONLY=false
FOLLOWER_CACHE_TTL=300
ANSWER_COOLDOWN_SECONDS=2.5
QUESTIONS_CATEGORY=
QUESTIONS_PATH_MAIN=/opt/your_project/data/questions.json
QUESTIONS_PATH_DOTA=/opt/your_project/data/questions_dota2.json
USER_QUESTIONS_DIR=/opt/your_project/data/user_questions
DB_PATH=/opt/your_project/game.db

# Bot user credentials
# Scopes for bot token should include chat permissions for sending messages.
TWITCH_BOT_USER_ACCESS_TOKEN=
TWITCH_BOT_USER_REFRESH_TOKEN=
TWITCH_BOT_USER_ID=
TWITCH_BOT_USER_LOGIN=your_bot_login
BOT_AUTH_ALLOWED_LOGINS=your_login
CHATBOT_BADGE_MODE=false
CHATBOT_CHATTERS_LIST_MODE=false
RUNTIME_STATE_BACKEND=memory
RUNTIME_STATE_NAMESPACE=twitch_guess_game
RUNTIME_STATE_REDIS_URL=
JOB_DISPATCHER_BACKEND=inline
JOB_DISPATCHER_NAMESPACE=twitch_guess_game

# Optional default channel for the legacy single overlay /overlay
TWITCH_BROADCASTER_ID=
TWITCH_CHANNEL_NAME=
